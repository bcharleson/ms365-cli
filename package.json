{
  "name": "ms365-cli",
  "version": "0.2.0",
  "description": "CLI and MCP server for Microsoft 365 — Mail, Calendar, OneDrive, Contacts. JSON-first, AI-agent ready.",
  "type": "module",
  "bin": {
    "m365": "./dist/index.js"
  },
  "files": [
    "dist",
    "install.sh",
    "skills",
    "M365.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "microsoft365",
    "outlook",
    "onedrive",
    "microsoft-graph",
    "cli",
    "mcp",
    "ai-agent",
    "email",
    "calendar"
  ],
  "author": "Brandon Charleson",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
